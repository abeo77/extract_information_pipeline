<mxfile host="app.diagrams.net">
  <diagram name="Evidence-Carrying Keyword Pipeline">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="Document Keyword Grouping &amp; Evidence Extraction Pipeline" style="text;html=1;strokeColor=none;fillColor=none;fontSize=24;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="330" y="20" width="900" height="40" as="geometry"/>
        </mxCell>

        <mxCell id="input" value="Input Document&lt;br&gt;PDF / TXT" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="120" width="150" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="load" value="Step 1&lt;br&gt;Load Document" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="120" width="150" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="normalize" value="Step 2&lt;br&gt;Normalize Text" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="420" y="120" width="150" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="segment" value="Step 3&lt;br&gt;Segment Document" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="120" width="150" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="extract" value="Step 4&lt;br&gt;Batch LLM Keyword + Evidence Extraction" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="105" width="190" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="group" value="Step 5&lt;br&gt;Batch LLM Keyword Grouping" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1030" y="105" width="190" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="merge" value="Step 6&lt;br&gt;Merge Evidence&lt;br&gt;Deterministic Code" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1260" y="105" width="170" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="validate" value="Step 7&lt;br&gt;Validate Evidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1260" y="270" width="170" height="80" as="geometry"/>
        </mxCell>

        <mxCell id="export" value="Step 8&lt;br&gt;Export Final JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="1030" y="275" width="190" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="final" value="Final Output&lt;br&gt;Structured JSON" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="275" width="190" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="load_detail" value="Loader Details&lt;br&gt;- PDF/TXT supported&lt;br&gt;- Preserve source path&lt;br&gt;- Preserve page metadata" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="220" y="240" width="170" height="100" as="geometry"/>
        </mxCell>

        <mxCell id="segment_detail" value="Segment Types&lt;br&gt;- numbered_section&lt;br&gt;- clause&lt;br&gt;- paragraph&lt;br&gt;- line&lt;br&gt;- fallback_chunk&lt;br&gt;- merge section across pages" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="590" y="240" width="190" height="130" as="geometry"/>
        </mxCell>

        <mxCell id="extract_detail" value="LLM Extraction Output&lt;br&gt;- raw_keyword&lt;br&gt;- keyword_type&lt;br&gt;- context_text&lt;br&gt;- exact_text&lt;br&gt;- page&lt;br&gt;- segment_id&lt;br&gt;- confidence" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="805" y="430" width="185" height="150" as="geometry"/>
        </mxCell>

        <mxCell id="group_detail" value="Grouping Rules&lt;br&gt;- Same / very close meaning&lt;br&gt;- Effective Date != End Date&lt;br&gt;- Renewal != Termination&lt;br&gt;- Payment != Liability&lt;br&gt;- Prefer precise groups" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff8e1;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1030" y="430" width="195" height="135" as="geometry"/>
        </mxCell>

        <mxCell id="validate_detail" value="Validation Rules&lt;br&gt;- context_text must come from segment&lt;br&gt;- exact_text must be inside context_text&lt;br&gt;- passed / failed / not_found&lt;br&gt;- Pydantic schema validation" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eaf7ea;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1250" y="430" width="210" height="125" as="geometry"/>
        </mxCell>

        <mxCell id="fallback" value="Optional Future Fallback&lt;br&gt;Retrieval / BM25 / Vector Search&lt;br&gt;Only if evidence missing or validation fails" style="rounded=1;dashed=1;whiteSpace=wrap;html=1;fillColor=#eeeeee;strokeColor=#999999;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="1250" y="620" width="230" height="90" as="geometry"/>
        </mxCell>

        <mxCell id="edge1" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="input" target="load">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge2" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="load" target="normalize">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge3" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="normalize" target="segment">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge4" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="segment" target="extract">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge5" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="extract" target="group">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge6" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="group" target="merge">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge7" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="merge" target="validate">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge8" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="validate" target="export">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge9" style="endArrow=block;html=1;strokeWidth=2;" edge="1" parent="1" source="export" target="final">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <mxCell id="edge10" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="load" target="load_detail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge11" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="segment" target="segment_detail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge12" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="extract" target="extract_detail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge13" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="group" target="group_detail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge14" style="endArrow=block;html=1;dashed=1;" edge="1" parent="1" source="validate" target="validate_detail">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="edge15" style="endArrow=block;html=1;dashed=1;strokeColor=#999999;" edge="1" parent="1" source="validate" target="fallback">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
